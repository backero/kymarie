# ====================================
# Kumarie - Environment Variables
# ====================================
# Copy this file to .env.local and fill in your values

# ----- Database -----
DATABASE_URL="postgresql://username:password@localhost:5432/kumarie_db"

# ----- Authentication -----
JWT_SECRET="your-super-secret-jwt-key-min-32-chars-long"
AUTH_SECRET="your-nextauth-secret-min-32-chars-long"
ADMIN_EMAIL="admin@kumarie.com"
ADMIN_PASSWORD="Admin@Kumarie2024"

# ----- Cloudinary (Image Storage) -----
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME="your-cloud-name"

# ----- Razorpay (Payments) -----
RAZORPAY_KEY_ID="rzp_test_xxxxxxxxxxxx"
RAZORPAY_KEY_SECRET="your-razorpay-secret"
NEXT_PUBLIC_RAZORPAY_KEY_ID="rzp_test_xxxxxxxxxxxx"

# ----- App Config -----
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Kumarie"

# ----- Email (Optional - for order notifications) -----
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your@gmail.com"
SMTP_PASS="your-app-password"
